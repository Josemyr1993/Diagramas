    AD -->|"LDAP / LDAPs"| LDAP_IDP
    GIT -->|"Webhook trigger"| TEKTON
    GIT -->|"GitOps sync"| ARGO
    DNS -->|"DNS resolution"| OCP

    CP -->|"schedules pods"| INFRA
    CP -->|"schedules pods"| WORKERS
    ARGO -->|"deploy manifests"| WORKERS
    TEKTON -->|"push image"| REG

    NOOBAA -->|"S3 OBC backend"| REG
    OSD1 & OSD2 & OSD3 --> NOOBAA
